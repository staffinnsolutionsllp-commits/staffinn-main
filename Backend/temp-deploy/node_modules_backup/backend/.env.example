# Staffinn Backend Environment Variables

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# DynamoDB Configuration
# For local DynamoDB testing, use:
# AWS_ACCESS_KEY_ID=dummy
# AWS_SECRET_ACCESS_KEY=dummy
# DYNAMODB_ENDPOINT=http://localhost:8000

# DynamoDB Tables
DYNAMODB_USERS_TABLE=staffinn-users
STAFF_TABLE=staffinn-staff-profiles
ADMIN_TABLE=staffinn-admin
JOBS_TABLE=staffinn-jobs
JOB_APPLICATIONS_TABLE=staffinn-job-applications

# HRMS Tables
HRMS_USERS_TABLE=staffinn-hrms-users
HRMS_EMPLOYEES_TABLE=staffinn-hrms-employees
HRMS_ATTENDANCE_TABLE=staffinn-hrms-attendance
HRMS_LEAVES_TABLE=HRMS-Leaves-Table
HRMS_PAYROLL_TABLE=staffinn-hrms-payroll

# Server Configuration
PORT=4001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# Admin Credentials (CWE-798, CWE-259 Fix)
# SECURITY: Set strong passwords and never commit actual passwords to version control
# Admin IDs (optional - defaults provided if not set)
STAFF_ADMIN_ID=staff_admin
RECRUITER_ADMIN_ID=recruiter_admin
INSTITUTE_ADMIN_ID=institute_admin

# Admin Passwords (required - must be set)
DEFAULT_ADMIN_PASSWORD=your-secure-admin-password-here
STAFF_ADMIN_PASSWORD=your-secure-staff-password-here
RECRUITER_ADMIN_PASSWORD=your-secure-recruiter-password-here
INSTITUTE_ADMIN_PASSWORD=your-secure-institute-password-here

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# S3 Bucket
S3_BUCKET_NAME=your-s3-bucket-name

# Email Configuration (SES)
SES_REGION=ap-south-1
FROM_EMAIL=noreply@staffinn.com

# Testing (Optional - Only for running test scripts)
# SECURITY: Never commit actual tokens to version control
# CWE-798, CWE-259 Fix: Use environment variables for test credentials
TEST_AUTH_TOKEN=your-test-token-here-for-testing-only
TEST_HRMS_EMAIL=test@example.com
TEST_HRMS_PASSWORD=your-test-password-here
TEST_PAYROLL_MONTH=2024-03
API_URL=http://localhost:5000/api/v1

# Bridge Service (for biometric attendance)
BRIDGE_SERVICE_URL=http://localhost:3002
